# ----------------------------------------------------------------------------
# Example environment file — copy to .env and customize before deploy
# ----------------------------------------------------------------------------

# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=please_generate_a_strong_random_secret_at_least_32_chars_long

# Admin bootstrap account (created on first launch if missing)
ADMIN_BOOTSTRAP_EMAIL=admin@egp-exchange.local

# Frontend origins for CORS
USER_FRONTEND_ORIGIN=http://localhost:3000
ADMIN_FRONTEND_ORIGIN=http://localhost:3001

# Backend base URL used by frontends
PUBLIC_API_URL=http://localhost:8080
PUBLIC_WS_URL=ws://localhost:8080
