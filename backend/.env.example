# =====================
# Server
# =====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=info
RUST_LOG=egp_exchange_backend=debug,axum=info,tower_http=info

# =====================
# Database (PostgreSQL)
# =====================
DATABASE_URL=postgres://egp:egp_strong_password@postgres:5432/egp_exchange
DATABASE_MAX_CONNECTIONS=20

# =====================
# Redis
# =====================
REDIS_URL=redis://redis:6379/0

# =====================
# Auth / JWT
# =====================
JWT_SECRET=change_this_to_a_64char_random_secret_in_production_please_use_openssl_rand_hex_32
JWT_ACCESS_TTL_HOURS=24
JWT_REFRESH_TTL_DAYS=30
ADMIN bootstrap email used on first launch to seed an admin account
ADMIN_BOOTSTRAP_EMAIL=admin@egp-exchange.local

# =====================
# Binance
# =====================
BINANCE_WS_URL=wss://stream.binance.com:9443/stream
BINANCE_REST_URL=https://api.binance.com
BINANCE_STREAMS=btcusdt@bookTicker,ethusdt@bookTicker,usdtusdc@bookTicker
# EGP/USD reference rate provider (Central Bank of Egypt fallback static rate)
EGP_USD_RATE=48.5
CIRCUIT_BREAKER_TIMEOUT_SECS=30
CIRCUIT_BREAKER_MAX_FAILURES=5

# =====================
# CORS
# =====================
USER_FRONTEND_ORIGIN=http://localhost:3000
ADMIN_FRONTEND_ORIGIN=http://localhost:3001

# =====================
# Manual Tx queue (Redis keys prefix)
# =====================
QUEUE_PREFIX=egp_exchange
